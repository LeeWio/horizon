# Horizon Blog Platform Environment Configuration
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=Horizon Blog Platform
APP_VERSION=1.0.0
APP_DESCRIPTION=A modern blog platform built with Spring Boot
APP_CONTACT_NAME=Horizon Development Team
APP_CONTACT_URL=https://github.com/sunrizon/horizon
APP_CONTACT_EMAIL=dev@sunrizon.com
APP_LICENSE_NAME=MIT License
APP_LICENSE_URL=https://opensource.org/licenses/MIT
APP_SERVER_URL=http://localhost:8080

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_EXPIRATION_HOURS=24

# 数据库配置
DB_USERNAME=root
DB_PASSWORD=G7v!p9Xq$2RfL8kM

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# 邮件配置
MAIL_HOST=smtp.qq.com
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-email-password-here
MAIL_DEFAULT_ENCODING=UTF-8

# RabbitMQ 配置
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# 文件上传配置
FILE_UPLOAD_MAX_SIZE=10MB
FILE_UPLOAD_MAX_REQUEST_SIZE=10MB
FILE_UPLOAD_DIR=uploads

# CORS 配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# 安全配置
BCRYPT_STRENGTH=12
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_CAPACITY=200

# 日志配置
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_HORIZON=DEBUG

# 开发环境配置
SPRING_PROFILES_ACTIVE=dev
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_OPEN_IN_VIEW=true
